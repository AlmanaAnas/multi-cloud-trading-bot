# ── Terraform ──────────────────────────────────────────────

# Local state — never commit real state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform working directories
**/.terraform/

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# Lock file — DO commit this, it pins provider versions
# .terraform.lock.hcl  ← intentionally not ignored

# Compiled Lambda/Function zip files
**/dist/*.zip

# ── Secrets — never commit these ──────────────────────────

# Secret tfvars — use terraform.tfvars only for non-sensitive values
*.secret.tfvars
*secret*.tfvars
secrets.tfvars

# Service account key files
service-account-key.json
*-key.json
*.pem
*.key
credentials.json

# ── Python ─────────────────────────────────────────────────

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/

# ── IDE ────────────────────────────────────────────────────

.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Local environment ──────────────────────────────────────

.env
.env.local
.env.*.local